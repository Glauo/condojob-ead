NODE_ENV=production
PORT=3000

APP_BASE_URL=https://seudominio.com.br
NEXT_PUBLIC_APP_URL=https://seudominio.com.br
JWT_SECRET=troque-por-um-segredo-forte
ADMIN_KEY=troque-por-uma-chave-admin

# Uploads persistentes fora da pasta do app
UPLOADS_DIR=/home/usuario/uploads/condojob

# Primeiro administrador criado automaticamente no boot
DEFAULT_ADMIN_LOGIN=admin
DEFAULT_ADMIN_PASSWORD=250488
DEFAULT_ADMIN_EMAIL=admin@seudominio.com.br
DEFAULT_ADMIN_NAME=Administrador

# Plataforma comercial padrao
DEFAULT_COMMERCIAL_LOGIN=comercial
DEFAULT_COMMERCIAL_PASSWORD=250488
DEFAULT_COMMERCIAL_EMAIL=comercial@seudominio.com.br
DEFAULT_COMMERCIAL_NAME=Equipe Comercial

# Credenciais-alvo para MySQL na Hostinger
DB_CLIENT=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=condojobead
MYSQL_USER=seu_usuario_mysql
MYSQL_PASSWORD=sua_senha_mysql

# Enquanto a camada SQL do app nao for migrada, o projeto ainda usa DATABASE_URL PostgreSQL.
# Este campo so deve ser mantido se voce estiver executando a versao atual sem migracao completa.
DATABASE_URL=
