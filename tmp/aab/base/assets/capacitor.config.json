{
	"appId": "com.condojob.app",
	"appName": "CondoJob",
	"webDir": "dist/public",
	"server": {
		"androidScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"launchAutoHide": true,
			"backgroundColor": "#1a0530",
			"androidSplashResourceName": "splash",
			"androidScaleType": "CENTER_CROP",
			"showSpinner": false
		},
		"StatusBar": {
			"backgroundColor": "#1a0530",
			"style": "LIGHT"
		},
		"Keyboard": {
			"resize": "body",
			"resizeOnFullScreen": true
		}
	}
}
